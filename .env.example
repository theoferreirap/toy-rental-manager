# -----------------------------------------------------------------------------
# TOY RENTAL MANAGER - Environment Variables Template
# Copy this file to a new file named '.env' and fill in the values.
# DO NOT commit '.env' containing real secrets to version control.
# -----------------------------------------------------------------------------

# --- Database Configuration ---
# Connection string for MySQL / TiDB database
# Format: mysql://username:password@host:port/database_name?ssl={"rejectUnauthorized":true}
DATABASE_URL="mysql://root:password@127.0.0.1:3306/toy_rental_db"

# --- Authentication & Session Security ---
# Secret key used to sign and verify JWT cookies (use a long, random string in production)
JWT_SECRET="your_jwt_secret_key_here_must_be_random_and_secure"

# --- OAuth & Platform Integration (Manus Auth) ---
# Client ID / Application ID for the Manus OAuth portal
VITE_APP_ID="your_manus_app_id"
# The backend URL for the OAuth authentication server
OAUTH_SERVER_URL="https://auth.manus.im"
# OpenID of the project owner for administrator role assignment
OWNER_OPEN_ID="your_owner_openid"

# --- Built-in APIs & AI Features (Forge Service) ---
# Base URL for built-in platform APIs (including LLM, voice transcription, storage)
BUILT_IN_FORGE_API_URL="https://api.forge.manus.im"
# Server-side API key for built-in services access
BUILT_IN_FORGE_API_KEY="your_server_forge_api_key"

# Frontend access configurations
VITE_FRONTEND_FORGE_API_URL="https://api.forge.manus.im"
VITE_FRONTEND_FORGE_API_KEY="your_frontend_forge_api_key"

# --- Server Configuration ---
NODE_ENV="development"
PORT=3000
